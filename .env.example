# .env.example


/**
 * ==========================================
 * ENVIRONMENT VARIABLES TEMPLATE
 * ==========================================
 *
 * This file is a template for required environment variables.
 *
 * It is safe to commit to version control.
 * Developers must copy this file to `.env` and fill in values.
 *
 * Purpose:
 * - Document required configuration
 * - Help new developers set up the project quickly
 * - Prevent leaking real secrets
 */

DB_USERNAME=
DB_PASSWORD=

# Generate using: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRATION=3600000

MAIL_USERNAME=
MAIL_PASSWORD=

APP_BASE_URL=http://localhost:8080

ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=admin123